# ─────────────────────────────────────────────
# NeoGaming Backend — Variables de Entorno
# Copiar este archivo como .env y completar los valores
# NUNCA commitear .env al repositorio
# ─────────────────────────────────────────────

# ── Base de datos ──
DB_URL=jdbc:postgresql://localhost:5432/neogaming
DB_USERNAME=neogaming
DB_PASSWORD=neogaming

# ── JWT ──
# Mínimo 64 caracteres para HMAC-SHA256
JWT_SECRET=neogaming-super-secret-dev-key-change-in-production-64chars!!
JWT_ACCESS_TOKEN_MINUTES=15
JWT_REFRESH_TOKEN_DAYS=30

# ── Email (dev: Mailhog) ──
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=

# ── Mercado Pago Colombia ──
# Obtener en: https://www.mercadopago.com.co/developers
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
MP_WEBHOOK_SECRET=

# ── Negocio ──
PLATFORM_FEE_PERCENTAGE=5.0

# ── Spring ──
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8080
