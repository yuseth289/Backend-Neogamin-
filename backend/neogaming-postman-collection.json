{
  "info": {
    "name": "NeoGaming Backend",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "productId", "value": "" },
    { "key": "categoryId", "value": "" },
    { "key": "orderId", "value": "" },
    { "key": "checkoutId", "value": "" },
    { "key": "addressId", "value": "" },
    { "key": "wishlistId", "value": "" },
    { "key": "sellerId", "value": "" }
  ],
  "item": [
    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "Registrar usuario",
          "event": [{ "listen": "test", "script": { "exec": [
            "if (pm.response.code === 201) {",
            "  const d = pm.response.json().data;",
            "  pm.collectionVariables.set('accessToken', d.accessToken);",
            "  pm.collectionVariables.set('refreshToken', d.refreshToken);",
            "}"
          ] } }],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"cliente@neogaming.co\",\n  \"password\": \"Password123!\",\n  \"firstName\": \"Carlos\",\n  \"lastName\": \"García\",\n  \"phone\": \"3001234567\"\n}" }
          }
        },
        {
          "name": "Login",
          "event": [{ "listen": "test", "script": { "exec": [
            "if (pm.response.code === 200) {",
            "  const d = pm.response.json().data;",
            "  pm.collectionVariables.set('accessToken', d.accessToken);",
            "  pm.collectionVariables.set('refreshToken', d.refreshToken);",
            "}"
          ] } }],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"cliente@neogaming.co\",\n  \"password\": \"Password123!\"\n}" }
          }
        },
        {
          "name": "Refresh token",
          "event": [{ "listen": "test", "script": { "exec": [
            "if (pm.response.code === 200) {",
            "  const d = pm.response.json().data;",
            "  pm.collectionVariables.set('accessToken', d.accessToken);",
            "}"
          ] } }],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/refresh",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}" }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/logout",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{}" }
          }
        }
      ]
    },
    {
      "name": "👤 Usuario",
      "item": [
        {
          "name": "Mi perfil",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/users/me",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        },
        {
          "name": "Actualizar perfil",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/users/me",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"firstName\": \"Carlos\",\n  \"lastName\": \"García\",\n  \"phone\": \"3009876543\"\n}" }
          }
        },
        {
          "name": "Cambiar contraseña",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/users/me/password",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"currentPassword\": \"Password123!\",\n  \"newPassword\": \"NuevaPassword456!\"\n}" }
          }
        }
      ]
    },
    {
      "name": "📦 Catálogo — Categorías",
      "item": [
        {
          "name": "Listar categorías",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/categories"
          }
        },
        {
          "name": "Obtener categoría por slug",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/categories/videojuegos"
          }
        },
        {
          "name": "Crear categoría (ADMIN)",
          "event": [{ "listen": "test", "script": { "exec": [
            "if (pm.response.code === 201) {",
            "  pm.collectionVariables.set('categoryId', pm.response.json().data.id);",
            "}"
          ] } }],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/categories",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Videojuegos\",\n  \"description\": \"Consolas, juegos y accesorios\",\n  \"parentId\": null\n}" }
          }
        },
        {
          "name": "Actualizar categoría (ADMIN)",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/categories/{{categoryId}}",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Videojuegos y Consolas\",\n  \"description\": \"Consolas, juegos, accesorios y más\"\n}" }
          }
        },
        {
          "name": "Eliminar categoría (ADMIN)",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/categories/{{categoryId}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        }
      ]
    },
    {
      "name": "🛍️ Catálogo — Productos",
      "item": [
        {
          "name": "Buscar productos",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/products?q=mouse&page=0&size=12",
              "host": ["{{baseUrl}}"],
              "path": ["products"],
              "query": [
                { "key": "q", "value": "mouse" },
                { "key": "page", "value": "0" },
                { "key": "size", "value": "12" }
              ]
            }
          }
        },
        {
          "name": "Buscar (search avanzado)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/products/search?q=teclado&category={{categoryId}}&minPrice=50000&maxPrice=500000",
              "host": ["{{baseUrl}}"],
              "path": ["products", "search"],
              "query": [
                { "key": "q", "value": "teclado" },
                { "key": "category", "value": "{{categoryId}}" },
                { "key": "minPrice", "value": "50000" },
                { "key": "maxPrice", "value": "500000" }
              ]
            }
          }
        },
        {
          "name": "Productos por categoría",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/products/category/{{categoryId}}"
          }
        },
        {
          "name": "Detalle producto por slug",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/products/mouse-gamer-rgb"
          }
        },
        {
          "name": "Mis productos (SELLER)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/products/me",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        },
        {
          "name": "Crear producto (SELLER)",
          "event": [{ "listen": "test", "script": { "exec": [
            "if (pm.response.code === 201) {",
            "  pm.collectionVariables.set('productId', pm.response.json().data.id);",
            "}"
          ] } }],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/products",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Mouse Gamer RGB Inalámbrico\",\n  \"description\": \"Mouse profesional para gaming con 6 botones programables\",\n  \"brand\": \"Logitech\",\n  \"sku\": \"LOG-G502-RGB\",\n  \"categoryId\": \"{{categoryId}}\",\n  \"basePrice\": 250000.00,\n  \"ivaPercent\": 19.00\n}" }
          }
        },
        {
          "name": "Actualizar producto (SELLER)",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/products/me/{{productId}}",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Mouse Gamer RGB Inalámbrico Pro\",\n  \"description\": \"Mouse profesional para gaming con 8 botones programables\",\n  \"basePrice\": 280000.00,\n  \"ivaPercent\": 19.00\n}" }
          }
        },
        {
          "name": "Publicar producto (SELLER)",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/products/me/{{productId}}/publish",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        },
        {
          "name": "Pausar producto (SELLER)",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/products/me/{{productId}}/pause",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        },
        {
          "name": "Eliminar producto (SELLER)",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/products/me/{{productId}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        },
        {
          "name": "Agregar imagen (SELLER)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/products/me/{{productId}}/images",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"url\": \"https://cdn.neogaming.co/products/mouse-rgb-1.jpg\",\n  \"altText\": \"Mouse RGB vista frontal\"\n}" }
          }
        }
      ]
    },
