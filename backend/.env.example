# ─────────────────────────────────────────────
# NeoGaming Backend — Variables de Entorno
# Copiar este archivo como .env y completar los valores
# NUNCA commitear .env al repositorio
# ─────────────────────────────────────────────

# ── Base de datos ──
DB_URL=jdbc:postgresql://localhost:5432/neogaming
DB_USERNAME=neogaming
DB_PASSWORD=neogaming

# ── JWT ──
# Mínimo 64 caracteres para HMAC-SHA256
JWT_SECRET=neogaming-super-secret-dev-key-change-in-production-64chars!!
JWT_ACCESS_TOKEN_MINUTES=15
JWT_REFRESH_TOKEN_DAYS=30

# ── Email (dev: Mailhog) ──
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=

# ── Mercado Pago Colombia ──
# Obtener en: https://www.mercadopago.com.co/developers
# Rule 8: Solo claves de prueba (TEST-) en este archivo. NUNCA escribir APP_USR- aquí.
MP_ACCESS_TOKEN=TEST-your-access-token-here
MP_PUBLIC_KEY=TEST-your-public-key-here
MP_WEBHOOK_SECRET=your-webhook-signing-secret-here
MP_SANDBOX=true

# ── Negocio ──
PLATFORM_FEE_PERCENTAGE=5.0

# ── CORS ──
# URLs del frontend separadas por comas. Sin espacios.
CORS_ALLOWED_ORIGINS=https://your-frontend.up.railway.app

# ── AI Service ──
AI_SERVICE_URL=http://ai-service:8001
AI_INTERNAL_SECRET=your-strong-random-secret-here

# ── Spring ──
SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080
